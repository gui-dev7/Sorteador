{
  "name": "sorteador-fiap-vercel",
  "private": true,
  "version": "3.2.0",
  "type": "module",
  "description": "Sorteador FIAP premium preparado para deploy direto na Vercel com Vite, React, TypeScript e API serverless.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:vercel": "vercel dev",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.vercel.json --noEmit"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.6.4",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "engines": {
    "node": "20.x"
  }
}
